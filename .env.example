# AVIATOR LLM configuration (override workflow JSON without editing files)
# Copy to .env and set values. Used by docker compose and can be sourced for local runs.

# OpenAI-compatible API (vLLM, Together, Groq, OpenAI, etc.)
# For Docker: use host.docker.internal instead of localhost to reach vLLM on host
AVIATOR_LLM_BASE_URL=http://host.docker.internal:18446/v1
AVIATOR_LLM_API_KEY=your-api-key
AVIATOR_LLM_MODEL=Qwen/Qwen2.5-Coder-32B-Instruct

# HuggingFace in-process (optional)
# AVIATOR_LLM_PATH=Qwen/Qwen2.5-Coder-32B-Instruct

# Fine-tuned model (optional, FT workflow vul_inject_SFT agent)
# AVIATOR_LLM_FINETUNED_PATH=/path/to/LoRA_FT/outputs
